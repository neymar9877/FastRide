<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- TOP CARD: address inputs -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Pickup Location"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1F4E79"/>

            <EditText
                android:id="@+id/etPickupAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Rothschild 32, Tel Aviv"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏁 Dropoff Location"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1F4E79"/>

            <EditText
                android:id="@+id/etDropAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="e.g. Dizengoff Center, Tel Aviv"
                android:inputType="text"
                android:layout_marginBottom="12dp"/>

            <Button
                android:id="@+id/btnFindDrivers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔍 Find Drivers"
                android:backgroundTint="#2E75B6"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Status text -->
    <TextView
        android:id="@+id/tvRideStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="#2E75B6"
        android:gravity="center"
        android:padding="8dp"/>

    <!-- Drivers list label -->
    <TextView
        android:id="@+id/tvDriversLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Available Drivers (tap to select)"
        android:textStyle="bold"
        android:textSize="14sp"
        android:textColor="#333333"
        android:paddingStart="16dp"
        android:paddingBottom="4dp"
        android:visibility="gone"/>

    <!-- Drivers RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDrivers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:visibility="gone"/>

    <!-- Confirm button -->
    <Button
        android:id="@+id/btnConfirmRide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:text="✅ Confirm Ride"
        android:backgroundTint="#1F4E79"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:visibility="gone"/>

    <!-- Logout -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:paddingVertical="12dp"
        android:text="Log out"
        android:textAllCaps="false"
        android:textColor="#E53935"
        android:textSize="14sp"
        app:backgroundTint="@android:color/transparent"
        app:strokeColor="#E53935"
        app:strokeWidth="1dp"/>

</LinearLayout>
